@{
    ViewData["Title"] = "Caro Offline";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="text-center">
    <h1 class="theme-text">Chế độ chơi Offline</h1>
    <p id="turnStatus" class="theme-text">Lượt của: X</p>
</div>

<div class="d-flex justify-content-center">
    <div id="game-board"></div>
</div>

@section Styles {
    <style>
        #game-board {
            margin-top: 20px;
            width: fit-content;
        }

        .row {
            display: flex;
        }

        .cell {
            width: 50px;
            height: 50px;
            border: 1px solid var(--cell-border-color, black);
            text-align: center;
            font-size: 24px;
            cursor: pointer;
            line-height: 50px;
            color: var(--cell-text-color, black);
        }

        .player-x {
            color: #00aaff;
            font-weight: bold;
        }

        .player-o {
            color: #ff6666;
            font-weight: bold;
        }

        body.dark-mode .cell {
            --cell-border-color: white;
            --cell-text-color: white;
        }

        body:not(.dark-mode) .cell {
            --cell-border-color: black;
            --cell-text-color: black;
        }
    </style>
}

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const board = document.getElementById("game-board");
            let currentPlayer = "X";

            function updateStatus() {
                document.getElementById("turnStatus").textContent = "Lượt của: " + currentPlayer;
            }

            function handleClick(cell, i, j) {
                if (cell.textContent !== "") return;
                cell.textContent = currentPlayer;
                cell.classList.add(currentPlayer === "X" ? "player-x" : "player-o");
                currentPlayer = currentPlayer === "X" ? "O" : "X";
                updateStatus();
            }

            for (let i = 0; i < 11; i++) {
                const row = document.createElement("div");
                row.classList.add("row");

                for (let j = 0; j < 11; j++) {
                    const cell = document.createElement("div");
                    cell.classList.add("cell");
                    cell.onclick = () => handleClick(cell, i, j);
                    row.appendChild(cell);
                }

                board.appendChild(row);
            }

            updateStatus();
        });
    </script>
}
