@using System.Security.Claims
@{
    ViewData["Title"] = "Game Cờ Caro";
    var roomId = ViewBag.RoomId;
    var userId = ViewBag.UserId;
    var avatarPath = ViewBag.AvatarPath;
    var displayName = ViewBag.DisplayName;
    var myScore = ViewBag.MyScore;
}

<style>
    .info-panel {
        position: fixed;
        left: 0;
        top: 50%;
        transform: translateY(-50%);
        width: 420x;
        display: flex;
        flex-direction: column;
        gap: 16px;
        z-index: 1000;
        padding-left: 20px;
    }

    .game-main-wrapper {
        
        display: flex;
        justify-content: center;
        align-items: center;
        width: 100%;
        padding: 0;
        box-sizing: border-box;
    }

    #game-area-wrapper {
        margin-left: 500px;
        margin-top: 4px;
        margin-right: auto;
        width: fit-content;
        display: flex;
        justify-content: center;
        align-items: center;
        height: 70vh;
    }

    #game-board-wrapper {
        display: grid;
        grid-template-columns: repeat(10, 1fr);
        width: 360px;
        aspect-ratio: 1 / 1;
        background-color: var(--bs-body-bg);
    }

    .cell {
        aspect-ratio: 1 / 1;
        border: 1px solid #555;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
        font-weight: bold;
    }

    .avatar-frame {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        overflow: hidden;
        border: 2px solid;
        background-color: #000;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .avatar-frame img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
            border-radius: 50%;
        }

    .chat-message {
        padding: 6px 12px;
        border-radius: 20px;
        max-width: 75%;
        word-wrap: break-word;
    }

        .chat-message.you {
            align-self: flex-end;
            background-color: #0d6efd;
            color: white;
        }

        .chat-message.other {
            align-self: flex-start;
            background-color: #f1f1f1;
            color: #000;
        }

    body.dark-mode .chat-message.other {
        background-color: #333;
        color: #e0e0e0;
    }

    #chat-box {
        display: flex;
        flex-direction: column;
        gap: 8px;
        height: 200px;
        overflow-y: auto;
        padding: 8px;
    }

    .info-box {
        border: 2px solid;
        border-radius: 10px;
        padding: 12px;
    }

    .info-top-container {
        max-width: 760px;
        margin: 0 auto 12px auto;
        margin-top: 2px;
        display: flex;
        gap: 2px;
        flex-wrap: wrap;
        justify-content: center;
    }

    .leave-btn {
        border: 1px solid #dc3545;
        background: transparent;
        color: #dc3545;
        transition: 0.3s;
    }

        .leave-btn:hover {
            background: #dc3545;
            color: white;
        }

    body.dark-mode .leave-btn {
        color: #ff8888;
        border-color: #ff8888;
    }

        body.dark-mode .leave-btn:hover {
            background-color: #f44336;
            color: #fff;
        }

    body.dark-mode #chat-container {
        background-color: #1e1e1e;
        border-color: #444;
    }

    body.dark-mode #message-input {
        background-color: #222;
        color: #fff;
        border-color: #555;
    }

    body:not(.dark-mode) #message-input {
        background-color: #fff;
        color: #000;
    }
</style>

<main id="gameMain" class="transition-margin d-flex flex-column align-items-center text-center gap-2">
    <h1 class="display-4 theme-text fw-bold" style="font-size: 1.75rem; text-shadow: 2px 2px 0 #000, 4px 4px 0 #0ff;">
        MULTIPLAYER - ONLINE
    </h1>


    <div class="info-top-container">
        <div class="info-box theme-box">
            @if (!string.IsNullOrEmpty(roomId) && roomId != "undefined")
            {
                <div><strong>Chế độ:</strong> @(roomId.StartsWith("Ranked_") ? "Đấu xếp hạng" : "Đấu thường")</div>
                @if (!roomId.StartsWith("Ranked_"))
                {
                    <div><strong>Mã phòng:</strong> @roomId</div>
                }
                <div class="mt-2">
                    <button id="leaveRoomBtn" class="btn leave-btn btn-sm" onclick="leaveGame()">⬅ Rời phòng</button>
                </div>
            }
        </div>
        <div class="info-box theme-box">
            <div><strong>Ký hiệu của bạn:</strong> <span id="playerSymbol">⏳</span></div>
            <div><strong>Trạng thái:</strong> <span id="turnStatus">⏳ Chờ...</span></div>
        </div>
    </div>

    <div class="info-panel">
        <div class="theme-box p-3" style="border: 2px solid #ff0055;">
            <div class="d-flex align-items-center gap-3">
                <div class="avatar-frame opponent-avatar" style="border-color: #ff0055;">
                    <img id="opponentAvatar" src="/uploads/avatars/default-opponent.jpg" alt="Avatar đối thủ">
                </div>
                <div class="d-flex flex-column text-start small">
                    <span><strong>Tên:</strong> <span id="opponentName">Đang chờ...</span></span>
                    <span><strong>ID:</strong> <span id="opponentId">...</span></span>
                    <span><strong>Điểm:</strong> <span id="opponentScore">0</span></span>
                    
                </div>
            </div>
        </div>

        <div id="chat-container" class="theme-box d-flex flex-column" style="border: 1px solid #333; border-radius: 10px;">
            <div id="chat-box" class="chat-box"></div>
            <div class="d-flex p-2 border-top">
                <input id="message-input" type="text" class="form-control me-2" placeholder="Nhắn tin..." />
                <button onclick="sendMessage()" class="btn btn-primary rounded-circle" style="width: 40px; height: 40px;">
                    <i class="bi bi-send"></i>
                </button>
            </div>
        </div>

        <div class="theme-box p-3" style="border: 2px solid #00ff00;">
            <div class="d-flex align-items-center gap-3">
                <div class="avatar-frame" style="border-color: #00ff00;">
                    <img src="@avatarPath" alt="Avatar">
                </div>
                <div class="d-flex flex-column text-start small">
                    <span><strong>Tên:</strong> @displayName</span>
                    <span><strong>ID:</strong> @userId</span>
                    <span><strong>Điểm:</strong> <span id="myScore">@myScore</span></span>
                    
                </div>
            </div>
        </div>
    </div>

    <div class="game-main-wrapper">
        <div id="game-area-wrapper">
            <div id="game-board-wrapper">
                @for (int i = 0; i < 10; i++)
                {
                    for (int j = 0; j < 10; j++)
                    {
                        <div id="cell-@i-@j" class="cell" onclick="makeMove(@i, @j)"></div>
                    }
                }
            </div>
        </div>
    </div>
</main>

<audio id="bgMusic" src="~/music/game.mp3" autoplay loop></audio>
<button id="siteMusicToggleBtn" class="btn btn-sm btn-outline-light theme-text"
        style="position: fixed; bottom: 10px; right: 10px; z-index: 999;">
    🔊 Tắt Nhạc
</button>

@section Scripts {
    <script>
        window.userId = "@userId";
        window.displayName = "@displayName";
        window.avatarPath = "@avatarPath";
        window.roomId = "@roomId";

        function appendMessage(senderId, senderName, avatarPath, message) {
            const box = document.getElementById("chat-box");
            const container = document.createElement("div");
            container.className = "d-flex " + (senderId === userId ? "justify-content-end" : "justify-content-start");

            const msgBubble = document.createElement("div");
            msgBubble.className = "chat-message " + (senderId === userId ? "you" : "other");

            const avatar = document.createElement("img");
            avatar.src = avatarPath || "/uploads/avatars/default.jpg";
            avatar.className = "rounded-circle me-2";
            avatar.style.width = "24px";
            avatar.style.height = "24px";

            const text = document.createElement("span");
            text.innerHTML = `<strong>${senderName}:</strong> ${message}`;
            msgBubble.appendChild(text);

            if (senderId === userId) {
                container.appendChild(msgBubble);
                container.appendChild(avatar);
            } else {
                container.appendChild(avatar);
                container.appendChild(msgBubble);
            }

            box.appendChild(container);
            box.scrollTop = box.scrollHeight;
        }

        function sendMessage() {
            const input = document.getElementById("message-input");
            const text = input.value.trim();
            if (!text) return;

            if (window.connection && connection.invoke) {
                connection.invoke("SendMessageToRoom", roomId, userId, displayName, text, avatarPath)
                    .catch(err => console.error("Lỗi gửi tin nhắn:", err));
            }

            input.value = "";
        }

        document.getElementById("message-input")?.addEventListener("keypress", function (e) {
            if (e.key === "Enter") {
                e.preventDefault();
                sendMessage();
            }
        });

        if (window.connection) {
            window.connection.on("ReceiveMessage", (senderId, senderName, message, avatarPath) => {
                appendMessage(senderId, senderName, avatarPath, message);
            });
        }
    </script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.0/signalr.min.js"></script>
    <script src="~/js/game.js" defer></script>
}
