@model AdminCreateUserViewModel
@{
    ViewData["Title"] = "Thêm người dùng mới (Manager)";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="card p-4 shadow-lg cyberpunk-card">
    <h4 class="mb-4 neon-text">
        <i class="bi bi-person-plus-fill text-success"></i> Thêm người dùng mới
    </h4>
    <form asp-controller="Manager" asp-action="Create" enctype="multipart/form-data" method="post" class="cyberpunk-form">
        <div class="form-group mb-3">
            <label asp-for="Email" class="form-label neon-text">Email</label>
            <input asp-for="Email" class="form-control cyberpunk-input neon-border" placeholder="example@email.com" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>
        <div class="form-group mb-3">
            <label asp-for="DisplayName" class="form-label neon-text">Tên hiển thị</label>
            <input asp-for="DisplayName" class="form-control cyberpunk-input neon-border" placeholder="Tên hiển thị" />
            <span asp-validation-for="DisplayName" class="text-danger"></span>
        </div>
        <div class="form-group mb-3">
            <label asp-for="Password" class="form-label neon-text">Mật khẩu</label>
            <input asp-for="Password" type="password" class="form-control cyberpunk-input neon-border" placeholder="Mật khẩu..." />
            <span asp-validation-for="Password" class="text-danger"></span>
        </div>
        <div class="form-group mb-3">
            <label asp-for="Avatar" class="form-label neon-text">Ảnh đại diện</label>
            <input asp-for="Avatar" type="file" class="form-control cyberpunk-input neon-border" />
            <span asp-validation-for="Avatar" class="text-danger"></span>
        </div>
        <div class="form-group mb-3">
            <label asp-for="Score" class="form-label neon-text">Điểm</label>
            <input asp-for="Score" type="number" min="0" class="form-control cyberpunk-input neon-border" />
            <span asp-validation-for="Score" class="text-danger"></span>
        </div>
        @* Không cho Manager chọn Role khác *@
        <input type="hidden" asp-for="Role" value="User" />
        <div class="form-group mb-4">
            <label class="form-label neon-text">Vai trò</label>
            <input type="text" class="form-control cyberpunk-input neon-border" value="User" readonly />
        </div>
        <button type="submit" class="btn cyberpunk-btn neon-btn">
            <i class="bi bi-plus-circle"></i> Thêm người dùng
        </button>
        <a asp-action="Index" class="btn btn-secondary ms-2 cyberpunk-btn neon-btn">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
    </form>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
