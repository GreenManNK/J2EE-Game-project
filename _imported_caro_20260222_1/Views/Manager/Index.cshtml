@model IEnumerable<Caro.Models.ApplicationUser>

@{
    ViewData["Title"] = "Quản lý người dùng (Manager)";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var userRoles = ViewBag.UserRoles as Dictionary<string, string>;
}

<h2>Quản lý người dùng (Manager)</h2>

<a asp-controller="Manager" asp-action="Create" class="btn btn-success mb-3">
    + Thêm người dùng
</a>

<form method="get" class="mb-3">
    <div class="row">
        <div class="col-md-6">
            <div class="input-group">
                <input type="text" name="searchTerm" value="@ViewBag.SearchTerm" class="form-control" placeholder="Tìm theo email hoặc tên hiển thị..." />
                <button type="submit" class="btn btn-primary">Tìm</button>
            </div>
        </div>
        <div class="col-md-3">
            <select name="banFilter" class="form-select w-auto" onchange="this.form.submit()">
                <option value="" selected="@(string.IsNullOrEmpty(ViewBag.BanFilter) ? "selected" : null)">Tất cả</option>
                <option value="banned" selected="@(ViewBag.BanFilter == "banned" ? "selected" : null)">Bị ban</option>
                <option value="active" selected="@(ViewBag.BanFilter == "active" ? "selected" : null)">Đang hoạt động</option>
            </select>
        </div>
    </div>
</form>

<table class="table table-bordered table-striped mt-2 theme-text">
    <thead class="theme-table-header">
        <tr>
            <th>Avatar</th>
            <th>Tên hiển thị</th>
            <th>Email</th>
            <th>Điểm</th>
            <th>Vai trò</th>
            <th>Trạng thái</th>
            <th>Hành động</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            var role = userRoles != null && userRoles.ContainsKey(user.Id) ? userRoles[user.Id] : "User";
            bool isBanned = user.BannedUntil != null && user.BannedUntil > DateTime.Now;

            <tr>
                <td>
                    <img src="@user.AvatarPath" alt="Avatar" width="40" height="40" style="border-radius: 50%;" />
                </td>
                <td>@user.DisplayName</td>
                <td>@user.Email</td>
                <td>@user.Score</td>
                <td>@role</td>
                <td>
                    @if (isBanned)
                    {
                        <span class="badge bg-danger">Banned</span>
                    }
                    else
                    {
                        <span class="badge bg-success">Active</span>
                    }
                </td>
                <td>
                    <a asp-controller="Manager" asp-action="Details" asp-route-id="@user.Id" class="btn btn-sm btn-info me-1">Chi tiết</a>
                    @if (role != "Admin")
                    {
                        <a asp-controller="Manager" asp-action="Edit" asp-route-id="@user.Id" class="btn btn-sm btn-primary">Sửa</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
