@model AdminCreateUserViewModel

@{
    ViewData["Title"] = "Thêm người dùng mới";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="card p-4 shadow-sm">
    <h4 class="mb-4 theme-text">
        <i class="bi bi-person-plus-fill text-success"></i> Thêm người dùng mới
    </h4>

    <form asp-action="Create" enctype="multipart/form-data" method="post" class="theme-text">
        <div class="form-group mb-3">
            <label asp-for="Email" class="form-label">Email</label>
            <input asp-for="Email" class="form-control" placeholder="example@email.com" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label asp-for="DisplayName" class="form-label">Tên hiển thị</label>
            <input asp-for="DisplayName" class="form-control" placeholder="Tên hiển thị" />
            <span asp-validation-for="DisplayName" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label asp-for="Password" class="form-label">Mật khẩu</label>
            <input asp-for="Password" type="password" class="form-control" placeholder="Mật khẩu..." />
            <span asp-validation-for="Password" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label asp-for="Avatar" class="form-label">Ảnh đại diện</label>
            <input asp-for="Avatar" type="file" class="form-control" />
            <span asp-validation-for="Avatar" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label asp-for="Score" class="form-label">Điểm</label>
            <input asp-for="Score" type="number" min="0" class="form-control" />
            <span asp-validation-for="Score" class="text-danger"></span>
        </div>

        <div class="form-group mb-4">
            <label asp-for="Role" class="form-label">Vai trò</label>
            <select asp-for="Role" class="form-select">
                <option value="User">User</option>
                <option value="Manager">Manager</option>
                <option value="Admin">Admin</option>
            </select>
            <span asp-validation-for="Role" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-success">
            <i class="bi bi-plus-circle"></i> Thêm người dùng
        </button>
        <a asp-action="Index" class="btn btn-secondary ms-2">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
