@model AdminEditUserViewModel

@{
    ViewData["Title"] = "Chỉnh sửa người dùng";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="card p-4 shadow-sm">
    <h4 class="theme-text mb-4">
        <i class="bi bi-pencil-square text-warning"></i> Chỉnh sửa người dùng
    </h4>

    <form asp-action="Edit" enctype="multipart/form-data" class="theme-text">
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="ExistingAvatarPath" />

        <div class="mb-3">
            <label asp-for="Email" class="form-label">Email</label>
            <input asp-for="Email" class="form-control" readonly />
        </div>

        <div class="mb-3">
            <label asp-for="DisplayName" class="form-label">Tên hiển thị</label>
            <input asp-for="DisplayName" class="form-control" />
        </div>

        <div class="mb-3">
            <label asp-for="Score" class="form-label">Điểm</label>
            <input asp-for="Score" class="form-control" type="number" />
        </div>

        <div class="mb-3">
            <label class="form-label">Ảnh đại diện hiện tại</label><br />
            @if (!string.IsNullOrEmpty(Model.ExistingAvatarPath))
            {
                <img src="@Model.ExistingAvatarPath" alt="Avatar hiện tại" class="rounded-circle border" style="width: 80px; height: 80px;" />
            }
        </div>

        <div class="mb-3">
            <label asp-for="Avatar" class="form-label">Chọn ảnh đại diện mới</label>
            <input asp-for="Avatar" type="file" class="form-control" />
        </div>

        @if (User.Identity?.Name != Model.Email)
        {
            <div class="mb-4">
                <label asp-for="Role" class="form-label">Vai trò</label>
                <select asp-for="Role" class="form-select">
                    <option value="User">User</option>
                    <option value="Manager">Manager</option>
                    <option value="Admin">Admin</option>
                </select>
            </div>
        }
        else
        {
            <div class="mb-4">
                <label asp-for="Role" class="form-label">Vai trò</label>
                <input class="form-control" value="@Model.Role" disabled />
                <input type="hidden" asp-for="Role" />
            </div>
        }

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-save"></i> Lưu thay đổi
            </button>
            <a asp-action="Index" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Quay lại
            </a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
