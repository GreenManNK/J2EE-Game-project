@{
    ViewData["Title"] = "Chat với Bot";
    ViewData["FullWidth"] = true;
}

<div class="bot-chat-wrapper">
    <div class="bot-chat-container">
        <div class="chat-header">🤖 Trợ lý ảo CyberBot</div>

        <div id="chat-box" class="chat-box"></div>

        <form id="chat-form" class="chat-form">
            <input type="text" id="userMessage" class="chat-input" placeholder="Nhập tin nhắn..." required />
            <button type="submit" class="chat-send-btn"><i class="bi bi-send-fill"></i></button>
        </form>
    </div>
</div>

@section Styles {
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />
    <style>
        .bot-chat-wrapper {
            width: 100%;
            display: flex;
            justify-content: center;
            padding: 2rem 1rem;
            background-color: transparent;
        }

        .bot-chat-container {
            width: clamp(700px, 90%, 1200px); /* mở rộng tối đa 1200px, không quá hẹp */
            display: flex;
            flex-direction: column;
            border: 1px solid var(--border-color);
            border-radius: 12px;
            background-color: var(--bg);
            color: var(--text);
            font-family: 'Segoe UI', sans-serif;
            height: 80vh;
        }

        .chat-header {
            padding: 1rem;
            background-color: var(--header-bg);
            border-bottom: 1px solid var(--border-color);
            font-weight: bold;
            text-transform: uppercase;
        }

        .chat-box {
            flex: 1;
            overflow-y: auto;
            padding: 1rem;
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
        }

        .chat-form {
            display: flex;
            padding: 0.75rem;
            border-top: 1px solid var(--border-color);
            background-color: var(--footer-bg);
            gap: 0.5rem;
        }

        .chat-input {
            flex: 1;
            border-radius: 20px;
            padding: 0.5rem 1rem;
            border: 1px solid var(--border-color);
            background-color: var(--input-bg);
            color: var(--text);
        }

        .chat-send-btn {
            background-color: var(--accent);
            color: #000;
            border: none;
            padding: 0.5rem 0.9rem;
            border-radius: 50%;
        }

        .msg {
            max-width: 75%;
            padding: 0.5rem 1rem;
            border-radius: 14px;
            font-size: 0.95rem;
            position: relative;
        }

            .msg small {
                display: block;
                font-size: 0.75rem;
                opacity: 0.6;
                margin-top: 4px;
            }

            .msg.user {
                align-self: flex-end;
                background-color: var(--blue);
                color: #fff;
            }

            .msg.bot {
                align-self: flex-start;
                background-color: var(--pink);
                color: #fff;
            }

        /* Cyberpunk variables (no neon) */
        body.dark-mode {
            --bg: #0f0f0f;
            --text: #fcee09;
            --header-bg: #191919;
            --footer-bg: #191919;
            --border-color: #444;
            --input-bg: #1a1a1a;
            --accent: #fcee09;
            --blue: #007bff;
            --pink: #dc408c;
        }

        body:not(.dark-mode) {
            --bg: #ffffff;
            --text: #000;
            --header-bg: #f0f0f0;
            --footer-bg: #f0f0f0;
            --border-color: #ccc;
            --input-bg: #fff;
            --accent: #fcee09;
            --blue: #007bff;
            --pink: #ff4081;
        }
    </style>
}

@section Scripts {
    <script>
        const chatBox = document.getElementById("chat-box");
        const form = document.getElementById("chat-form");
        const input = document.getElementById("userMessage");

        form.addEventListener("submit", async function (e) {
            e.preventDefault();

            const message = input.value.trim();
            if (!message) return;

            appendMessage("user", message);
            input.value = "";

            try {
                const res = await fetch("/ChatBot/SendMessage", {
                    method: "POST",
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded'
                    },
                    body: `message=${encodeURIComponent(message)}`
                });

                const data = await res.json();

                if (data.success) {
                    appendMessage("bot", data.reply);
                } else {
                    appendMessage("bot", data.message);
                }
            } catch (err) {
                appendMessage("bot", "❌ Lỗi kết nối tới máy chủ.");
            }

            chatBox.scrollTop = chatBox.scrollHeight;
        });

        function appendMessage(sender, text) {
            const msg = document.createElement("div");
            msg.classList.add("msg", sender);
            const time = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
            msg.innerHTML = `<strong>${sender === "user" ? "Bạn" : "Bot"}:</strong> ${text.replace(/\n/g, "<br/>")}<br/><small>${time}</small>`;
            chatBox.appendChild(msg);
        }
    </script>
}
