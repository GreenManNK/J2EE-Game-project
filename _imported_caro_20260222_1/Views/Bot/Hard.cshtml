@{
    ViewData["Title"] = "Đấu với Bot Khó";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="text-center">
    <h1 class="theme-text">Đấu với máy: Khó</h1>
    <p id="turnStatus" class="theme-text">Lượt của: X</p>
</div>

<div class="d-flex justify-content-center">
    <div id="game-board"></div>
</div>

<!-- Modal thông báo kết quả -->
<div id="resultModal" class="modal">
    <div class="modal-content">
        <span class="close-btn" onclick="closeResult()">×</span>
        <h2 id="resultMessage" class="result-text fw-bold"></h2>
        <button onclick="resetBoardOnServer()" class="btn btn-success mt-3">🔄 Chơi lại</button>
    </div>
</div>

<style>
    #game-board {
        margin-top: 20px;
        width: fit-content;
        border: 2px solid var(--board-border-color, #333);
        border-radius: 10px;
        padding: 10px;
    }

    .row {
        display: flex;
    }

    .cell {
        width: 50px;
        height: 50px;
        border: 1px solid var(--cell-border-color, black);
        text-align: center;
        font-size: 24px;
        cursor: pointer;
        line-height: 50px;
        color: var(--cell-text-color, black);
        transition: transform 0.1s ease, background-color 0.3s ease;
    }

        .cell:hover {
            transform: scale(1.1);
            box-shadow: 0 0 10px rgba(0, 255, 255, 0.6);
        }

    .player-x {
        color: #00aaff;
        font-weight: bold;
    }

    .player-o {
        color: #ff6666;
        font-weight: bold;
    }

    body.dark-mode .cell {
        --cell-border-color: white;
        --cell-text-color: #9be7ff;
    }

    body:not(.dark-mode) .cell {
        --cell-border-color: black;
        --cell-text-color: black;
    }

    .theme-text {
        color: var(--theme-text-color, black);
    }

    body.dark-mode .theme-text {
        color: #9be7ff;
    }

    /* Modal backdrop */
    .modal {
        display: none;
        position: fixed;
        z-index: 1050;
        left: 0;
        top: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0, 0, 0, 0.5);
        padding-top: 100px;
    }

    .modal-content {
        background-color: #fefefe;
        margin: auto;
        padding: 30px;
        border-radius: 12px;
        width: 80%;
        max-width: 400px;
        text-align: center;
        border: 2px solid #ff00cc;
        box-shadow: 0 0 20px #0ff;
        transition: background-color 0.3s, color 0.3s;
        animation: fadeIn 0.3s ease-in-out;
    }

    body.dark-mode .modal-content {
        background-color: #1f1f1f;
        color: #9be7ff;
        border-color: #ff00cc;
        box-shadow: 0 0 25px rgba(0, 255, 255, 0.4);
    }

    .result-text {
        font-size: 26px;
        margin-top: 10px;
        animation: pulse 1.5s infinite;
    }
    .close-btn {
        color: #999;
        float: right;
        font-size: 28px;
        font-weight: bold;
        cursor: pointer;
    }

        .close-btn:hover,
        .close-btn:focus {
            color: #f00;
            text-decoration: none;
        }
</style>

@section Scripts {
    <script>
        const boardSize = 11;
        let board = Array(boardSize).fill().map(() => Array(boardSize).fill(''));
        const boardElement = document.getElementById('game-board');
        let isBotThinking = false;
        let gameOver = false;

        for (let i = 0; i < boardSize; i++) {
            const row = document.createElement('div');
            row.classList.add('row');
            for (let j = 0; j < boardSize; j++) {
                const cell = document.createElement('div');
                cell.id = `cell-${i}-${j}`;
                cell.className = 'cell';
                cell.addEventListener('click', () => makeMove(i, j));
                row.appendChild(cell);
            }
            boardElement.appendChild(row);
        }

        function makeMove(x, y) {
            if (board[x][y] !== '' || isBotThinking || gameOver) return;

            board[x][y] = 'X';
            drawMove(x, y, 'X');
            document.getElementById('turnStatus').textContent = 'Lượt của: O';
            isBotThinking = true;

            fetch('/Bot/HardMove', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ x, y })
            })
            .then(res => res.json())
            .then(data => {
                if (data.playerWin) {
                    highlightWinLine(data.winLine);
                    showResult('🎉 Bạn đã thắng!');
                    gameOver = true;
                    return;
                }

                if (data.x !== null && data.y !== null) {
                    board[data.x][data.y] = 'O';
                    drawMove(data.x, data.y, 'O');

                    if (data.botWin) {
                        highlightWinLine(data.winLine);
                        showResult('🤖 Bot đã thắng!');
                        gameOver = true;
                        return;
                    }
                }

                isBotThinking = false;
                document.getElementById('turnStatus').textContent = 'Lượt của: X';
            });
        }

        function drawMove(x, y, symbol) {
            const cell = document.getElementById(`cell-${x}-${y}`);
            if (cell) {
                cell.textContent = symbol;
                if (symbol === 'X') cell.classList.add('player-x');
                else if (symbol === 'O') cell.classList.add('player-o');
            }
        }

        function highlightWinLine(line) {
            if (!line) return;
            line.forEach(pos => {
                const cell = document.getElementById(`cell-${pos.x}-${pos.y}`);
                if (cell) {
                    cell.style.backgroundColor = '#ffc107';
                    cell.style.transition = 'background-color 0.3s';
                }
            });
        }

        function showResult(message) {
            document.getElementById('resultMessage').textContent = message;
            document.getElementById('resultModal').style.display = 'block';
        }

        function closeResult() {
            document.getElementById('resultModal').style.display = 'none';
            resetBoard();
        }

        function resetBoard() {
            board = Array(boardSize).fill().map(() => Array(boardSize).fill(''));
            for (let i = 0; i < boardSize; i++) {
                for (let j = 0; j < boardSize; j++) {
                    const cell = document.getElementById(`cell-${i}-${j}`);
                    if (cell) {
                        cell.textContent = '';
                        cell.style.backgroundColor = '';
                        cell.classList.remove('player-x', 'player-o');
                    }
                }
            }
            document.getElementById('turnStatus').textContent = 'Lượt của: X';
        }

        function resetBoardOnServer() {
            fetch('/Bot/ResetHardBoard', { method: 'POST' })
                .then(() => {
                    resetBoard();
                    isBotThinking = false;
                    gameOver = false;
                    document.getElementById('resultModal').style.display = 'none';
                    document.getElementById('resultMessage').textContent = '';
                });
        }
    </script>
}
