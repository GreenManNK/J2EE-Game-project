@model dynamic
@{
    ViewData["Title"] = "Bảng xếp hạng";
    ViewData["FullWidth"] = true;
    var rank = 1;
}

<div class="mt-5 theme-box p-4" style="width: clamp(700px, 90%, 1200px); margin: 0 auto;">
    <h2 class="theme-text neon-glow mb-4">🏆 Bảng xếp hạng người chơi</h2>
    <table class="table table-hover table-borderless rounded shadow-sm overflow-hidden"
           style="background-color: var(--bg); color: var(--text);">
        <thead class="theme-text">
            <tr>
                <th>Hạng</th>
                <th>Avatar</th>
                <th>Tên hiển thị</th>
                <th>Điểm</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var player in Model)
            {
                var highlight = rank == 1 ? "fw-bold text-warning" : rank <= 3 ? "fw-semibold" : "";
                <tr class="cyberpunk-item">
                    <td><strong class="theme-text @highlight">@rank</strong></td>
                    <td>
                        <img src="@player.AvatarPath" width="48" height="48" class="rounded-circle shadow" alt="avatar" />
                    </td>
                    <td class="theme-text @highlight">@player.DisplayName</td>
                    <td class="theme-text">@player.Score</td>
                </tr>
                rank++;
            }
        </tbody>
    </table>
</div>
