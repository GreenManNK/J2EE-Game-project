@{
    ViewData["Title"] = "Chat với " + ViewBag.FriendName;
}

<div class="chat-container">
    <div class="chat-header">
        💬 Trò chuyện với <strong>@ViewBag.FriendName</strong>
        <span id="typingIndicator" style="font-size: 0.8rem; color: #888; margin-left: 10px;"></span>
    </div>

    <div id="chatBox" class="chat-body"></div>

    <div class="chat-footer">
        <input type="text" id="messageInput" placeholder="Nhập tin nhắn..." />
        <button id="sendButton" title="Gửi"><i class="bi bi-send-fill"></i></button>
    </div>
</div>

@section Styles {
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />
    <style>
        .chat-container {
            max-width: 700px;
            height: 85vh;
            margin: 30px auto;
            display: flex;
            flex-direction: column;
            border: 1px solid var(--border-color);
            border-radius: 12px;
            background: var(--bg);
            color: var(--text);
            font-family: 'Segoe UI', sans-serif;
        }

        .chat-header {
            padding: 1rem;
            border-bottom: 1px solid var(--border-color);
            background-color: var(--header-bg);
            font-weight: bold;
            text-transform: uppercase;
        }

        .chat-body {
            flex: 1;
            overflow-y: auto;
            padding: 1rem;
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
        }

        .chat-footer {
            display: flex;
            gap: 0.5rem;
            padding: 0.75rem 1rem;
            border-top: 1px solid var(--border-color);
            background-color: var(--footer-bg);
        }

            .chat-footer input {
                flex: 1;
                border-radius: 20px;
                border: 1px solid var(--border-color);
                background-color: var(--input-bg);
                padding: 0.5rem 1rem;
                color: var(--text);
            }

                .chat-footer input::placeholder {
                    color: #999;
                }

            .chat-footer button {
                background-color: var(--accent);
                color: #000;
                border: none;
                border-radius: 50%;
                padding: 0.5rem 0.8rem;
            }

        .message-wrapper {
            display: flex;
            align-items: flex-end;
            gap: 0.5rem;
        }

            .message-wrapper.self {
                flex-direction: row-reverse;
                align-self: flex-end;
            }

            .message-wrapper.friend {
                flex-direction: row;
                align-self: flex-start;
            }

        .chat-avatar {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            object-fit: cover;
            border: 1px solid var(--border-color);
        }

        .msg {
            max-width: 70%;
            padding: 0.5rem 1rem;
            border-radius: 16px;
            font-size: 0.95rem;
            position: relative;
        }

            .msg small {
                display: block;
                font-size: 0.75rem;
                opacity: 0.6;
                margin-top: 4px;
            }

            .msg.self {
                background-color: var(--blue);
                color: #fff;
            }

            .msg.friend {
                background-color: var(--pink);
                color: #fff;
            }

        /* Theme variables */
        body.dark-mode {
            --bg: #0f0f0f;
            --text: #fcee09;
            --header-bg: #1a1a1a;
            --footer-bg: #1a1a1a;
            --input-bg: #1f1f1f;
            --border-color: #444;
            --blue: #0056b3;
            --pink: #dc408c;
            --accent: #fcee09;
        }

        body:not(.dark-mode) {
            --bg: #ffffff;
            --text: #111;
            --header-bg: #f5f5f5;
            --footer-bg: #f5f5f5;
            --input-bg: #fff;
            --border-color: #ccc;
            --blue: #0056b3;
            --pink: #ff4081;
            --accent: #fcee09;
        }
    </style>
}

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.0/signalr.min.js"></script>
    <script>
        const currentUser = "@ViewBag.CurrentUserId";
        const friendId = "@ViewBag.FriendId";
        const friendName = "@ViewBag.FriendName";
        const currentAvatar = "@ViewBag.CurrentUserAvatarPath";
        const friendAvatar = "@ViewBag.FriendAvatarPath";

        const chatBox = document.getElementById("chatBox");
        const messageInput = document.getElementById("messageInput");
        const typingIndicator = document.getElementById("typingIndicator");

        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/chathub")
            .build();

        connection.on("ReceiveMessage", (senderId, message, timestamp) => {
            if (senderId === currentUser) return;
            appendMessage(senderId, message, timestamp);
        });

        connection.on("ShowTyping", () => {
            typingIndicator.textContent = `${friendName} đang nhập...`;
            clearTimeout(window.typingTimeout);
            window.typingTimeout = setTimeout(() => typingIndicator.textContent = "", 2000);
        });

        connection.start().catch(err => console.error("SignalR Error:", err));

        document.getElementById("sendButton").addEventListener("click", sendMessage);
        messageInput.addEventListener("keydown", e => {
            if (e.key === "Enter" && !e.shiftKey) {
                e.preventDefault();
                sendMessage();
            }
        });

        messageInput.addEventListener("input", () => {
            connection.invoke("TypingTo", friendId).catch(console.error);
        });

        function sendMessage() {
            const msg = messageInput.value.trim();
            if (!msg) return;

            const now = new Date().toISOString();
            connection.invoke("SendPrivateMessage", friendId, msg)
                .catch(err => console.error("Send error:", err));

            appendMessage(currentUser, msg, now);
            messageInput.value = "";
        }

        function appendMessage(senderId, msg, timestamp) {
            const wrapper = document.createElement("div");
            wrapper.classList.add("message-wrapper", senderId === currentUser ? "self" : "friend");

            const avatar = document.createElement("img");
            avatar.src = senderId === currentUser ? currentAvatar : friendAvatar;
            avatar.className = "chat-avatar";

            const bubble = document.createElement("div");
            bubble.classList.add("msg", senderId === currentUser ? "self" : "friend");
            bubble.textContent = msg;

            const timeEl = document.createElement("small");
            timeEl.textContent = new Date(timestamp).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
            bubble.appendChild(document.createElement("br"));
            bubble.appendChild(timeEl);

            wrapper.appendChild(senderId === currentUser ? bubble : avatar);
            wrapper.appendChild(senderId === currentUser ? avatar : bubble);

            chatBox.appendChild(wrapper);
            chatBox.scrollTop = chatBox.scrollHeight;
        }
    </script>
}
