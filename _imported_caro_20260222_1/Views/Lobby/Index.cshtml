@using System.Security.Claims
@{
    ViewData["Title"] = "Lobby";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var userId = User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "guest_" + Guid.NewGuid().ToString("N");
    var displayName = User.Identity?.Name ?? "Khách chơi";
    var avatarPath = "/images/default-avatar.png";
}

<div class="container mt-5 text-center">
    <h1 class="display-4 theme-text fw-bold"
        style="text-shadow: 2px 2px 0 #000, 4px 4px 0 #0ff;">
        SẢNH
    </h1>

    <!-- Nút tìm trận + tạo phòng -->
    <div class="d-flex justify-content-center align-items-center flex-wrap gap-3 mt-4">
        <div class="input-group" style="width: 300px;">
            <input type="text" class="form-control" id="roomIdInput" placeholder="Nhập mã phòng...">
            <button class="btn btn-success" id="createRoomBtn" onclick="createRoom()">➕ Tạo phòng</button>
        </div>

        <button id="matchButton" class="btn btn-primary">🎯 Tìm trận</button>

        <div id="matchmakingStatus" class="text-info fw-bold small" style="display:none;">
            <span class="spinner-border spinner-border-sm me-2"></span>
            Đang tìm trận <span id="matchTimer">00:00</span>...
        </div>
    </div>

    <!-- Danh sách phòng -->
    <div class="card mx-auto theme-box cyberpunk-card mt-4" style="max-width: 600px;">
        <div class="card-header theme-text fw-bold">
            <i class="bi bi-door-open-fill"></i> Danh sách phòng đang chờ
        </div>
        <ul class="list-group list-group-flush" id="roomList">
            <li class="list-group-item">Đang tải danh sách phòng...</li>
        </ul>
    </div>
</div>

<!-- Nhạc nền -->
<audio id="siteMusic" src="~/music/lobby.mp3" autoplay loop></audio>
<button id="siteMusicToggleBtn" class="btn btn-sm btn-outline-light theme-text"
        style="position: fixed; bottom: 10px; right: 10px; z-index: 999; background-color: transparent;">
    🔊 Tắt Nhạc
</button>

<!-- Scripts -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
<script src="~/js/lobby.js"></script>

<script>
    const siteMusic = document.getElementById("siteMusic");
    const siteToggleBtn = document.getElementById("siteMusicToggleBtn");
    siteMusic.volume = 0.3;

    siteToggleBtn.addEventListener("click", () => {
        if (siteMusic.paused) {
            siteMusic.play();
            siteToggleBtn.textContent = "🔊 Tắt Nhạc";
        } else {
            siteMusic.pause();
            siteToggleBtn.textContent = "🔇 Bật Nhạc";
        }
    });

    window.addEventListener("load", () => {
        siteToggleBtn.textContent = siteMusic.paused ? "🔇 Bật Nhạc" : "🔊 Tắt Nhạc";
    });

    document.getElementById("roomIdInput").addEventListener("keydown", function (event) {
        if (event.key === "Enter") {
            event.preventDefault();
            document.getElementById("createRoomBtn").click();
        }
    });

    // Lưu thông tin người chơi
    const userId = "@userId";
    const displayName = "@displayName";
    const avatarPath = "@avatarPath";

    localStorage.setItem("userId", userId);
    localStorage.setItem("displayName", displayName);
    localStorage.setItem("avatarPath", avatarPath);

    // Điều khiển nút tìm trận
    let isFindingMatch = false;
    let seconds = 0;
    let timer = null;

    const matchBtn = document.getElementById("matchButton");
    const matchStatus = document.getElementById("matchmakingStatus");

    function formatTime(sec) {
        const m = String(Math.floor(sec / 60)).padStart(2, '0');
        const s = String(sec % 60).padStart(2, '0');
        return `${m}:${s}`;
    }

    function updateMatchStatusText() {
        matchStatus.querySelector("#matchTimer").textContent = formatTime(seconds);
    }

    matchBtn.addEventListener("click", function () {
        if (!window.connection) {
            alert("❌ Kết nối đến máy chủ thất bại.");
            return;
        }

        if (!isFindingMatch) {
            connection.invoke("FindMatch", userId, displayName, avatarPath)
                .then(() => {
                    isFindingMatch = true;
                    seconds = 0;
                    matchStatus.style.display = "block";
                    updateMatchStatusText();
                    matchBtn.classList.replace("btn-primary", "btn-danger");
                    matchBtn.textContent = "❌ Hủy tìm";

                    timer = setInterval(() => {
                        seconds++;
                        updateMatchStatusText();
                    }, 1000);
                })
                .catch(err => console.error("Lỗi tìm trận:", err));
        } else {
            connection.invoke("CancelMatchmaking")
                .then(() => {
                    isFindingMatch = false;
                    clearInterval(timer);
                    matchStatus.style.display = "none";
                    matchBtn.classList.replace("btn-danger", "btn-primary");
                    matchBtn.textContent = "🎯 Tìm trận";
                })
                .catch(err => console.error("Lỗi hủy tìm trận:", err));
        }
    });
</script>
