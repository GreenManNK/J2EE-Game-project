@{
    ViewData["Title"] = "Đặt lại mật khẩu";
    ViewData["FullWidth"] = true;
}

<div class="card theme-box mx-auto mt-5" style="max-width: 500px;">
    <div class="card-header">
        <h4 class="mb-0 theme-text">🔐 Đặt lại mật khẩu</h4>
    </div>
    <div class="card-body theme-text">
        <form method="post" asp-action="ResetPassword">
            <input type="hidden" name="userId" value="@ViewBag.UserId" />
            <input type="hidden" name="code" value="@ViewBag.Token" />

            <div class="mb-3">
                <label class="form-label" for="newPassword">Mật khẩu mới</label>
                <div class="input-group">
                    <input type="password" name="NewPassword" id="newPassword" class="form-control" placeholder="Nhập mật khẩu mới" required />
                    <button type="button" class="btn btn-outline-secondary" onclick="togglePassword('newPassword', this)">👁</button>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label" for="confirmPassword">Xác nhận mật khẩu</label>
                <div class="input-group">
                    <input type="password" name="ConfirmPassword" id="confirmPassword" class="form-control" placeholder="Xác nhận mật khẩu" required />
                    <button type="button" class="btn btn-outline-secondary" onclick="togglePassword('confirmPassword', this)">👁</button>
                </div>
            </div>

            <button class="btn btn-primary w-100">Cập nhật mật khẩu</button>
        </form>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success mt-3 text-center">
                🔄 Mật khẩu đã được đặt lại thành công! Đang chuyển về trang đăng nhập...
            </div>
            <script>
                setTimeout(() => window.location.href = '/Account/Login', 2000);
            </script>
        }
    </div>
</div>

@section Scripts {
    <script>
        function togglePassword(id, btn) {
            const input = document.getElementById(id);
            const isHidden = input.type === "password";
            input.type = isHidden ? "text" : "password";
            btn.innerText = isHidden ? "🙈" : "👁";
        }
    </script>
}
