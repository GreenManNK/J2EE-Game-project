@{
    ViewData["Title"] = "Quên mật khẩu";
    ViewData["FullWidth"] = true;
}

<div class="container mt-5" style="max-width: 500px;">
    <div class="card shadow">
        <div class="card-body">
            <h3 class="card-title text-center mb-4">
                <i class="bi bi-envelope-exclamation-fill"></i> Quên mật khẩu
            </h3>

            <form method="post" asp-action="SendResetCode">
                <div class="form-group mb-3">
                    <label for="email">Email đã đăng ký:</label>
                    <input type="email" name="email" id="email" required class="form-control" placeholder="Nhập email của bạn..." />
                </div>

                <button type="submit" class="btn btn-primary w-100">
                    <i class="bi bi-send-fill"></i> Gửi mã xác nhận
                </button>
            </form>

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger mt-3">@TempData["Error"]</div>
            }

            <p class="text-muted mt-4 text-center" style="font-size: 0.9em;">
                Nếu bạn không thấy email, hãy kiểm tra hộp thư rác (Spam).
            </p>
        </div>
    </div>
</div>
