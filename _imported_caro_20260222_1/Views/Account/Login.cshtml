@model Caro.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập";
    ViewData["FullWidth"] = true;
}

<div class="card theme-box mx-auto mt-5" style="max-width: 450px;">
    <div class="card-header">
        <h4 class="mb-0 theme-text">🔐 Đăng nhập</h4>
    </div>
    <div class="card-body theme-text">
        <form asp-action="Login" method="post">
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <!-- Email -->
            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" placeholder="Nhập email" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <!-- Mật khẩu -->
            <div class="mb-3">
                <label asp-for="Password" class="form-label"></label>
                <div class="input-group">
                    <input asp-for="Password" class="form-control" id="loginPassword" placeholder="Nhập mật khẩu" />
                    <button class="btn btn-outline-secondary" type="button" onclick="togglePassword('loginPassword', this)">👁</button>
                </div>
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <!-- Nhớ đăng nhập -->
            <div class="form-check mb-3">
                <input asp-for="RememberMe" class="form-check-input" id="rememberMeCheck" />
                <label asp-for="RememberMe" class="form-check-label" for="rememberMeCheck"></label>
            </div>

            <!-- Nút đăng nhập -->
            <button type="submit" class="btn btn-primary w-100">Đăng nhập</button>

            <!-- Quên mật khẩu -->
            <div class="text-center mt-2">
                <a asp-controller="Account" asp-action="RequestReset" class="btn btn-link">Quên mật khẩu?</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function togglePassword(inputId, btn) {
            const input = document.getElementById(inputId);
            const isHidden = input.type === "password";
            input.type = isHidden ? "text" : "password";
            btn.innerText = isHidden ? "🙈" : "👁";
        }
    </script>
}
