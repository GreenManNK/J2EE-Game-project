@model List<Caro.Models.ApplicationUser>

<div id="friendListContainer" class="card theme-box mb-3">
    <div class="card-header">
        <strong>Bạn bè</strong>
    </div>
    <ul class="list-group list-group-flush">
        @if (Model.Any())
        {
            @foreach (var friend in Model)
            {
                var statusColor = friend.IsOnline ? "limegreen" : "crimson";

                <li class="list-group-item theme-box">
                    <div class="d-flex align-items-center mb-2">
                        <div style="width: 10px; height: 10px; border-radius: 50%; background-color: @statusColor; margin-right: 8px;"></div>
                        <img src="@friend.AvatarPath" style="width: 30px; height: 30px; border-radius: 50%; margin-right: 10px;" />
                        <span>@friend.DisplayName</span>
                    </div>

                    <div class="btn-group btn-group-sm d-flex gap-1">
                        @if (friend.IsOnline)
                        {
                            <a href="#" class="btn btn-sm theme-outline-btn flex-fill" onclick="event.preventDefault(); challengeFriend('@friend.Id')">Thách đấu</a>
                        }
                        <a class="btn btn-sm theme-outline-btn flex-fill" asp-controller="Chat" asp-action="Private" asp-route-friendId="@friend.Id">Chat</a>
                        <a class="btn btn-sm theme-outline-btn flex-fill" asp-controller="Friendship" asp-action="UserDetail" asp-route-id="@friend.Id">Xem</a>
                    </div>
                </li>
            }
        }
        else
        {
            <li class="list-group-item theme-box">Không có bạn bè.</li>
        }
    </ul>
</div>
