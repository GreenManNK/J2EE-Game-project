@model Caro.ViewModels.FriendshipIndexViewModel

@{
    ViewData["Title"] = "Bạn bè";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <script src="~/js/site.js"></script>

}
<h2 class="text-white">Danh sách bạn bè</h2>
<ul class="list-group mb-4">
    @foreach (var friend in Model.Friends)
    {
        <li class="list-group-item d-flex justify-content-between align-items-center">
            <div>
                @friend.DisplayName (@friend.Email)
            </div>

            <div class="d-flex gap-2">
                <form asp-action="Remove" asp-controller="Friendship" asp-route-id="@friend.Id" method="post" onsubmit="return confirm('Bạn có chắc muốn hủy kết bạn?');">
                    <button class="btn btn-danger btn-sm">Hủy kết bạn</button>
                </form>

                <!-- Nút thách đấu -->
                <button class="btn btn-warning btn-sm"
                        onclick="challengeFriend('@friend.Id', '@friend.DisplayName')">
                    Thách đấu
                </button>
            </div>
        </li>
    }

</ul>

<h4 class="text-white">Lời mời kết bạn đang chờ</h4>
<ul class="list-group mb-4">
    @foreach (var request in Model.PendingRequests)
    {
        <li class="list-group-item d-flex justify-content-between align-items-center">
            @request.Requester.DisplayName (@request.Requester.Email)
            <form asp-action="Accept" asp-controller="Friendship" asp-route-id="@request.Id" method="post">
                <button class="btn btn-success btn-sm">Chấp nhận</button>
            </form>
        </li>
    }
</ul>

<h4 class="text-white">Gửi lời mời kết bạn</h4>
<form asp-action="SendRequest" method="post">
    <div class="input-group" style="max-width: 400px;">
        <input type="email" name="email" class="form-control" placeholder="Nhập email người dùng..." required />
        <button type="submit" class="btn btn-primary">Gửi lời mời</button>
    </div>
</form>

<audio id="siteMusic" src="~/music/friendship.mp3" autoplay loop></audio>
<button id="siteMusicToggleBtn" class="btn btn-sm btn-outline-light theme-text"
        style="position: fixed; bottom: 10px; right: 10px; z-index: 999; background-color: transparent;">
    🔊 Tắt Nhạc
</button>

<script>
    const siteMusic = document.getElementById("siteMusic");
    const siteToggleBtn = document.getElementById("siteMusicToggleBtn");

    siteMusic.volume = 0.3;

    siteToggleBtn.addEventListener("click", () => {
        if (siteMusic.paused) {
            siteMusic.play();
            siteToggleBtn.textContent = "🔊 Tắt Nhạc";
        } else {
            siteMusic.pause();
            siteToggleBtn.textContent = "🔇 Bật Nhạc";
        }
    });

    window.addEventListener("load", () => {
        siteToggleBtn.textContent = siteMusic.paused ? "🔇 Bật Nhạc" : "🔊 Tắt Nhạc";
    });
</script>
