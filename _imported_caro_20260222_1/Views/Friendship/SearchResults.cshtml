@model List<Caro.Models.ApplicationUser>
@{
    var exactMatches = ViewBag.ExactMatches as List<Caro.Models.ApplicationUser>;
    string query = ViewBag.Query as string;
}

<div class="theme-text" style="max-width: 720px; margin: 2rem auto;">
    <h2 class="theme-text">Kết quả tìm kiếm cho: <span style="color: var(--accent);">"@query"</span></h2>

    @if (exactMatches != null && exactMatches.Any())
    {
        <ul class="list-group mb-3">
            @foreach (var user in exactMatches)
            {
                <li class="list-group-item d-flex justify-content-between align-items-center theme-notification"
                    style="background-color: var(--bg); color: var(--text); border-color: var(--border-color);">
                    <div class="d-flex align-items-center">
                        <img src="@user.AvatarPath" style="width: 35px; height: 35px; border-radius: 50%; margin-right: 10px;" />
                        <span>@user.DisplayName (@user.Email)</span>
                    </div>
                    <a class="btn btn-sm theme-outline-btn theme-text" asp-action="UserDetail" asp-route-id="@user.Id">Xem chi tiết</a>
                </li>
            }
        </ul>
    }

    @if (Model != null && Model.Any())
    {
        <h4 class="theme-text" style="color: var(--accent);"><i class="bi bi-lightbulb"></i> Không tìm thấy! Có phải ý bạn là:</h4>
        <ul class="list-group">
            @foreach (var user in Model)
            {
                <li class="list-group-item d-flex justify-content-between align-items-center theme-notification"
                    style="background-color: var(--bg); color: var(--text); border-color: var(--border-color);">
                    <div class="d-flex align-items-center">
                        <img src="@user.AvatarPath"
                             alt="avatar"
                             class="rounded-circle shadow-sm me-2"
                             style="width: 40px; height: 40px; object-fit: cover; border: 1px solid var(--border-color);" />

                        <span>@user.DisplayName (@user.Email)</span>
                    </div>
                    <a class="btn btn-sm theme-outline-btn theme-text" asp-action="UserDetail" asp-route-id="@user.Id">Xem chi tiết</a>
                </li>
            }
        </ul>
    }
    else if ((exactMatches == null || !exactMatches.Any()) && (!Model?.Any() ?? true))
    {
        <div class="mt-3 theme-text" style="color: crimson;">
            <i class="bi bi-x-circle"></i> Không tìm thấy người dùng nào phù hợp.
        </div>
    }
</div>
