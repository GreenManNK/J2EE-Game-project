{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Game: Start (Default Public)",
      "type": "shell",
      "detail": "Start app production profile + public tunnel",
      "command": "cmd",
      "args": [
        "/c",
        "scripts\\manual-start.cmd",
        "--no-pause"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Game: Stop (All)",
      "type": "shell",
      "detail": "Stop app, Cloudflare tunnel, fallback tunnel, and Docker runtime if any",
      "command": "cmd",
      "args": [
        "/c",
        "scripts\\manual-start.cmd",
        "stop",
        "--no-pause"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    }
  ]
}
