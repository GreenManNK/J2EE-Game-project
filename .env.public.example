# Copy to .env.public.local and fill your values

# Public domain (required if you want stable access via named tunnel)
PUBLIC_BASE_URL=https://game.example.com
# Or set full path if your app is not under /Game
# PUBLIC_GAME_URL=https://game.example.com/Game

# Cloudflare named tunnel token (required for stable remote access via Cloudflare Tunnel)
CLOUDFLARE_TUNNEL_TOKEN=

# App runtime
WS_ALLOWED_ORIGINS=https://game.example.com
APP_EMAIL_MODE=log

# OAuth2 social login (Google/Facebook)
# Callback URL in provider console should point to:
#   https://<domain>/Game/login/oauth2/code/google
#   https://<domain>/Game/login/oauth2/code/facebook
# SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_GOOGLE_CLIENT_ID=
# SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_GOOGLE_CLIENT_SECRET=
# SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_GOOGLE_SCOPE=openid,profile,email
# SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_FACEBOOK_CLIENT_ID=
# SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_FACEBOOK_CLIENT_SECRET=
# SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_FACEBOOK_SCOPE=public_profile,email

# Production profile already disables local J2EE canonical guard.
# Keep these if you want to override:
# APP_ENFORCE_CANONICAL_URL=false

# Database mode:
# - auto (default): thu Laragon MySQL -> MySQL thuong -> H2 fallback (neu script bat fallback)
# - mysql: dung MySQL thuong/Laragon theo APP_DATASOURCE_MYSQL_*
# - postgres: dung PostgreSQL theo APP_DATASOURCE_POSTGRES_*
# - h2: buoc dung H2 file local
APP_DATASOURCE_KIND=auto

# MySQL (standard names; co the dung du cho MySQL service khong can Laragon)
APP_DATASOURCE_MYSQL_HOST=127.0.0.1
APP_DATASOURCE_MYSQL_PORT=3306
APP_DATASOURCE_MYSQL_DATABASE=caro
APP_DATASOURCE_MYSQL_USERNAME=root
APP_DATASOURCE_MYSQL_PASSWORD=

# Legacy Laragon aliases (van duoc ho tro de tuong thich nguoc)
# LARAGON_DB_HOST=127.0.0.1
# LARAGON_DB_PORT=3306
# LARAGON_DB_NAME=caro
# LARAGON_DB_USER=root
# LARAGON_DB_PASS=

# PostgreSQL (chi can khi APP_DATASOURCE_KIND=postgres)
# APP_DATASOURCE_POSTGRES_HOST=127.0.0.1
# APP_DATASOURCE_POSTGRES_PORT=5432
# APP_DATASOURCE_POSTGRES_DATABASE=caro
# APP_DATASOURCE_POSTGRES_USERNAME=postgres
# APP_DATASOURCE_POSTGRES_PASSWORD=
# APP_DATASOURCE_POSTGRES_SCHEMA=
# APP_DATASOURCE_POSTGRES_SSL_MODE=disable

# Optional portable fallback (auto-enabled by public scripts if MySQL is unavailable)
# APP_DATASOURCE_ALLOW_H2_FALLBACK=true
# APP_DATASOURCE_H2_FILE=.data/game-public

# Tunnel mode notes:
# - start script defaults to auto mode:
#   + if CLOUDFLARE_TUNNEL_TOKEN + PUBLIC_BASE_URL/PUBLIC_GAME_URL are set -> use named tunnel (stable URL)
#   + otherwise -> fallback to quick tunnel (*.trycloudflare.com)
