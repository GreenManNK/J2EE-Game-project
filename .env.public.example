# Copy to .env.public.local and fill your values

# Public domain (optional, for script output only)
PUBLIC_BASE_URL=https://game.example.com
# Or set full path if your app is not under /Game
# PUBLIC_GAME_URL=https://game.example.com/Game

# Cloudflare named tunnel token (required for stable remote access via Cloudflare Tunnel)
CLOUDFLARE_TUNNEL_TOKEN=

# App runtime
WS_ALLOWED_ORIGINS=https://game.example.com
APP_EMAIL_MODE=log

# Production profile already disables local J2EE canonical guard.
# Keep these if you want to override:
# APP_ENFORCE_CANONICAL_URL=false

# Database (uses existing app.datasource.laragon.* env names)
LARAGON_DB_HOST=127.0.0.1
LARAGON_DB_PORT=3306
LARAGON_DB_NAME=caro
LARAGON_DB_USER=root
LARAGON_DB_PASS=
