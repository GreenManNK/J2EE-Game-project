# Copy to .env.public.postgres.local
#
# Dung cho may chi co PostgreSQL Server.
# Database "caro" nen duoc tao san truoc (script hien khong tu create DB cho PostgreSQL).

PUBLIC_BASE_URL=https://game.example.com
# Hoac:
# PUBLIC_GAME_URL=https://game.example.com/Game
CLOUDFLARE_TUNNEL_TOKEN=

WS_ALLOWED_ORIGINS=https://game.example.com
APP_EMAIL_MODE=log

# OAuth2 social login (Google/Facebook)
# Callback URL:
#   https://<domain>/Game/login/oauth2/code/google
#   https://<domain>/Game/login/oauth2/code/facebook
# SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_GOOGLE_CLIENT_ID=
# SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_GOOGLE_CLIENT_SECRET=
# SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_GOOGLE_SCOPE=openid,profile,email
# SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_FACEBOOK_CLIENT_ID=
# SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_FACEBOOK_CLIENT_SECRET=
# SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_FACEBOOK_SCOPE=public_profile,email

APP_DATASOURCE_KIND=postgres
APP_DATASOURCE_ALLOW_H2_FALLBACK=false

APP_DATASOURCE_POSTGRES_HOST=127.0.0.1
APP_DATASOURCE_POSTGRES_PORT=5432
APP_DATASOURCE_POSTGRES_DATABASE=caro
APP_DATASOURCE_POSTGRES_USERNAME=postgres
APP_DATASOURCE_POSTGRES_PASSWORD=
# APP_DATASOURCE_POSTGRES_SCHEMA=public
APP_DATASOURCE_POSTGRES_SSL_MODE=disable
