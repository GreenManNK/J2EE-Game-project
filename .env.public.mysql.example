# Copy to .env.public.mysql.local
#
# Dung cho may khong co Laragon, chi co MySQL Server (co the quan ly bang Workbench/DBeaver/HeidiSQL...)
# Luu y: "management tool" chi la cong cu quan ly; van can MySQL Server dang chay.

PUBLIC_BASE_URL=https://game.example.com
# Hoac:
# PUBLIC_GAME_URL=https://game.example.com/Game
CLOUDFLARE_TUNNEL_TOKEN=

WS_ALLOWED_ORIGINS=https://game.example.com
APP_EMAIL_MODE=log

APP_DATASOURCE_KIND=mysql
APP_DATASOURCE_ALLOW_H2_FALLBACK=false

APP_DATASOURCE_MYSQL_HOST=127.0.0.1
APP_DATASOURCE_MYSQL_PORT=3306
APP_DATASOURCE_MYSQL_DATABASE=caro
APP_DATASOURCE_MYSQL_USERNAME=root
APP_DATASOURCE_MYSQL_PASSWORD=
